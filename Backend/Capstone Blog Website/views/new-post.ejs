<%- include("partials/header", { title: "New Post" }) %>

<div class="form-page">
  <div class="form-header">
    <a href="/" class="back-link">
      <i class="fa-solid fa-arrow-left"></i> Back to Home
    </a>
    <h1><i class="fa-solid fa-pen-nib"></i> Create New Post</h1>
    <p>Share your thoughts, stories, or ideas with the world.</p>
  </div>

  <div class="form-card">
    <form action="/posts" method="POST" class="post-form">
      <div class="form-group">
        <label for="title">Post Title <span class="required">*</span></label>
        <input
          type="text"
          id="title"
          name="title"
          placeholder="Give your post a compelling title..."
          required
          maxlength="150"
          autofocus
        />
      </div>

      <div class="form-group">
        <label for="author">Author Name</label>
        <input
          type="text"
          id="author"
          name="author"
          placeholder="Your name (defaults to Anonymous)"
          maxlength="80"
        />
      </div>

      <div class="form-group">
        <label for="content">Content <span class="required">*</span></label>
        <textarea
          id="content"
          name="content"
          rows="14"
          placeholder="Write your post content here..."
          required
        ></textarea>
      </div>

      <div class="form-actions">
        <a href="/" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-paper-plane"></i> Publish Post
        </button>
      </div>
    </form>
  </div>
</div>

<%- include("partials/footer") %>
