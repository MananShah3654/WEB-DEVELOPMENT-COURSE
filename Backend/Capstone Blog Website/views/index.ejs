<%- include("partials/header", { title: "Home" }) %>

<!-- Hero Banner -->
<section class="hero">
  <div class="hero-content">
    <h1>The Daily Thought</h1>
    <p>A personal space to write, reflect, and share ideas with the world.</p>
    <a href="/new" class="btn btn-primary btn-lg">
      <i class="fa-solid fa-pen-nib"></i> Start Writing
    </a>
  </div>
</section>

<!-- Posts Section -->
<section class="posts-section">
  <div class="section-header">
    <h2>All Posts</h2>
    <span class="post-count"><%= posts.length %> <%= posts.length === 1 ? "article" : "articles" %></span>
  </div>

  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <i class="fa-regular fa-file-lines fa-3x"></i>
      <h3>No posts yet</h3>
      <p>Be the first to share something. Every great blog starts with a single post.</p>
      <a href="/new" class="btn btn-primary">Write Your First Post</a>
    </div>
  <% } else { %>
    <div class="posts-grid">
      <% posts.forEach(post => { %>
        <article class="post-card">
          <div class="post-card-body">
            <div class="post-meta">
              <span class="post-author">
                <i class="fa-solid fa-user-pen"></i> <%= post.author %>
              </span>
              <span class="post-date">
                <i class="fa-regular fa-calendar"></i> <%= post.date %>
              </span>
            </div>
            <h3 class="post-title"><%= post.title %></h3>
            <p class="post-excerpt">
              <%= post.content.length > 200 ? post.content.substring(0, 200) + "..." : post.content %>
            </p>
          </div>
          <div class="post-card-footer">
            <a href="/edit/<%= post.id %>" class="btn btn-secondary btn-sm">
              <i class="fa-solid fa-pen-to-square"></i> Edit
            </a>
            <form action="/posts/<%= post.id %>/delete" method="POST" class="delete-form">
              <button
                type="submit"
                class="btn btn-danger btn-sm"
                onclick="return confirm('Delete this post? This action cannot be undone.')"
              >
                <i class="fa-solid fa-trash"></i> Delete
              </button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
